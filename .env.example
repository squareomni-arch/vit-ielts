# ─────────────────────────────────────────────────────────────
# Vit-IELTS — environment variables
# Copy to `.env.local` (dev) and set the same keys on the deploy
# platform (Coolify / Vercel) for production at https://vitielts.com.
# NEVER commit real values — this file documents key names only.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──
# Public (browser) — safe to expose
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — full DB access, used by ~supabase/admin. KEEP SECRET.
SUPABASE_SERVICE_ROLE_KEY=

# ── Media CDN / image transform (front the storage origin) ──
# Public CDN host fronting the Supabase storage origin (e.g. https://cdn.vitielts.com).
# Empty = serve media straight from NEXT_PUBLIC_SUPABASE_URL (toCdnUrl is a no-op).
NEXT_PUBLIC_MEDIA_CDN_URL=
# Set to "true" ONLY after imgproxy is enabled on the storage stack. Turns on the
# /storage/v1/render/image/... resize endpoint via getMediaImage(); otherwise the
# original image URL is served unchanged.
NEXT_PUBLIC_MEDIA_TRANSFORM_ENABLED=

# ── SePay payment webhook ──
# Shared secret sent by SePay as the `Authorization: Apikey <SECRET>` header
# to POST /api/webhooks/sepay. Must match the API Key configured in the
# SePay dashboard for the receiving bank account (ACB 2447967).
# Missing/incorrect value => webhook rejects all callbacks (500/401).
SEPAY_WEBHOOK_SECRET=

# Email that receives order/payout admin notifications.
# Defaults to admin@ieltspredictiontest.com if unset.
ADMIN_EMAIL=

# ── Media upload service ──
MEDIA_UPLOAD_URL=
MEDIA_UPLOAD_SECRET=
NEXT_PUBLIC_MEDIA_UPLOAD_URL=
NEXT_PUBLIC_MEDIA_UPLOAD_SECRET=

# ── Object-storage backup (scripts/backup-storage.ts → S3-compatible, e.g. Cloudflare R2) ──
BACKUP_S3_ENDPOINT=
BACKUP_S3_REGION=auto
BACKUP_S3_BUCKET=vitielts-media-backup
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
# pg_dump connection string for the DB backup (VPS only) — complements storage backup.
BACKUP_DB_URL=

# ── Orphan-media sweeper (scripts/sweep-orphan-media.ts) ──
# Objects unreferenced AND older than this many days are eligible for cleanup. Default 30.
MEDIA_SWEEP_GRACE_DAYS=30

# ── WordPress import/integration ──
WP_URL=
WP_ADMIN_USER=
WP_ADMIN_PASSWORD=

# ── Debug ──
# Set to "true" to enable verbose client-side debug logging.
NEXT_PUBLIC_DEBUG=
