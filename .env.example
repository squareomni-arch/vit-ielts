# ─────────────────────────────────────────────────────────────
# Vit-IELTS — environment variables
# Copy to `.env.local` (dev) and set the same keys on the deploy
# platform (Coolify / Vercel) for production at https://vitielts.com.
# NEVER commit real values — this file documents key names only.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──
# Public (browser) — safe to expose
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — full DB access, used by ~supabase/admin. KEEP SECRET.
SUPABASE_SERVICE_ROLE_KEY=

# ── SePay payment webhook ──
# Shared secret sent by SePay as the `Authorization: Apikey <SECRET>` header
# to POST /api/webhooks/sepay. Must match the API Key configured in the
# SePay dashboard for the receiving bank account (ACB 2447967).
# Missing/incorrect value => webhook rejects all callbacks (500/401).
SEPAY_WEBHOOK_SECRET=

# Email that receives order/payout admin notifications.
# Defaults to admin@ieltspredictiontest.com if unset.
ADMIN_EMAIL=

# ── Media upload service ──
MEDIA_UPLOAD_URL=
MEDIA_UPLOAD_SECRET=
NEXT_PUBLIC_MEDIA_UPLOAD_URL=
NEXT_PUBLIC_MEDIA_UPLOAD_SECRET=

# ── WordPress import/integration ──
WP_URL=
WP_ADMIN_USER=
WP_ADMIN_PASSWORD=

# ── Debug ──
# Set to "true" to enable verbose client-side debug logging.
NEXT_PUBLIC_DEBUG=
