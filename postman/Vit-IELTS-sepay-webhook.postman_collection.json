      }
    },
    {
      "name": "10. PAYOUT — auto-complete (transferType=out)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "const res = pm.response.json();",
              "pm.test('type = payout', () => pm.expect(res.type).to.eql('payout'));",
              "pm.test('updated = true (lần đầu)', () => pm.expect(res.updated).to.eql(true));",
              "console.log('Payout result:', JSON.stringify(res));",
              "// Chạy lại request này → updated=false (idempotent: sepay_id đã ghi nhận)."
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Apikey {{sepaySecret}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"gateway\": \"ACB\",\n  \"transactionDate\": \"2026-06-16 12:00:00\",\n  \"accountNumber\": \"2447967\",\n  \"content\": \"PAYOUT {{payoutId}}\",\n  \"transferType\": \"out\",\n  \"description\": \"Chi tra affiliate PAYOUT {{payoutId}}\",\n  \"transferAmount\": {{payoutAmount}},\n  \"referenceCode\": \"TEST-PAYOUT-001\",\n  \"id\": 991001\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/webhooks/sepay",
          "host": ["{{baseUrl}}"],
          "path": ["api", "webhooks", "sepay"]
        },
        "description": "Mô phỏng SePay báo tiền RA cho một payout đang ở trạng thái 'approved'.\n- `content` phải đúng định dạng 'PAYOUT <uuid 36 ký tự>'.\n- `transferType` = 'out'.\n- `transferAmount` phải KHỚP CHÍNH XÁC `payouts.amount` (không có sai số như order); lệch → payout bị 'flagged', updated=false.\n- Idempotency theo `id` (sepay_id) qua bảng `sepay_payout_transactions`."
      }
    }
  ],
