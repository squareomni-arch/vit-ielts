              "  pm.expect(res.error).to.include('Missing required fields'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Apikey {{sepaySecret}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"gateway\": \"ACB\",\n  \"transferType\": \"in\",\n  \"id\": 990007\n}"
