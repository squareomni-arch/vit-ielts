          "raw": "{\n  \"gateway\": \"ACB\",\n  \"transactionDate\": \"2026-06-16 11:00:00\",\n  \"accountNumber\": \"2447967\",\n  \"content\": \"Vit IELTS 00000000000000000\",\n  \"transferType\": \"in\",\n  \"transferAmount\": {{orderAmount}},\n  \"referenceCode\": \"TEST-NOTFOUND\",\n  \"id\": 990008\n}"
        },
