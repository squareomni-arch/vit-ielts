        "url": {
          "raw": "{{baseUrl}}/api/webhooks/sepay",
          "host": ["{{baseUrl}}"],
          "path": ["api", "webhooks", "sepay"]
        },
        "description": "Auth hợp lệ nhưng thiếu `transferAmount` và `content` → 400 'Missing required fields'."
      }
    },
    {
